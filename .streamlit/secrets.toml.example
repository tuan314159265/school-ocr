# Streamlit Secrets — file mẫu (không chứa key thật)
#
# Copy file này, đổi tên thành secrets.toml và điền API key của bạn.
# Trên Streamlit Cloud, vào Settings -> Secrets và thêm các dòng sau:
#
# api_key = "AIzaSy_your_key_here"
# model = "gemini-2.0-flash"
api_key = ""
model = "gemini-2.0-flash"
